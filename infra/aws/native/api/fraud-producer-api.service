[Unit]
Description=Fraud Log Pipeline Producer API
After=network-online.target
Wants=network-online.target

[Service]
User=ec2-user
Group=ec2-user
WorkingDirectory=/opt/fraud-log-pipeline/producer-api
EnvironmentFile=/etc/fraud-log-pipeline/api.env
ExecStart=/opt/fraud-log-pipeline/producer-api/.venv/bin/uvicorn app.main:app --host 0.0.0.0 --port 8000
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
